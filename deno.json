{
  "name": "@aura-stack/router",
  "version": "0.7.2",
  "tasks": {
    "dev": "deno run --watch src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts",
    "./endpoint": "./src/endpoint.ts",
    "./error": "./src/error.ts",
    "./headers": "./src/headers.ts",
    "./cookie": "./src/cookie.ts",
    "./client": "./src/client.ts",
    "./types": "./src/@types/index.ts"
  },
  "imports": {
    "@/": "./src/",
    "cookie": "npm:cookie@^1.1.1",
    "zod": "npm:zod@^4.1.11",
    "arktype": "npm:arktype@^2.0.0",
    "valibot": "npm:valibot@^1.4.0",
    "typebox": "npm:typebox@^1.1.38"
  },
  "publish": {
    "include": ["./src/**/*.ts", "./README.md", "./LICENSE", "./CHANGELOG.md"]
  },
  "exclude": ["dist", "node_modules", "docs", "coverage"]
}
